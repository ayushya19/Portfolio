# Environment Variables Template
# Copy this file to .env.local and fill in your actual values

# Site Configuration
NEXT_PUBLIC_SITE_NAME=Ayushya Rao Portfolio
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Contact Information
NEXT_PUBLIC_CONTACT_EMAIL=contact@ayushyarao.com

# Analytics (Optional)
# NEXT_PUBLIC_GOOGLE_ANALYTICS_ID=

# Optional: Add your social media links
# NEXT_PUBLIC_LINKEDIN_URL=
# NEXT_PUBLIC_GITHUB_URL=
# NEXT_PUBLIC_TWITTER_URL=

# Form Submission (Optional - for backend integration)
# FORM_SUBMISSION_ENDPOINT=
# FORM_SUBMISSION_API_KEY=
